generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ═══════════════════════════════════════════
// MULTI-TENANT: Organizations
// ═══════════════════════════════════════════

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  domain      String?
  plan        String   @default("free") // free, starter, pro, enterprise
  status      String   @default("active") // active, suspended, deleted
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  groups      Group[]
  students    Student[]
  payments    Payment[]
  expenses    Expense[]
  attendance  Attendance[]
  homework    Homework[]
  grades      Grade[]
  schedule    ScheduleEntry[]
  messages    Message[]
  library     Book[]
  exams       Exam[]
  certificates Certificate[]
  qrCodes     QrCode[]
  auditLogs   AuditLog[]
  devices     Device[]
  notifications Notification[]
  branches    OrganizationBranch[]
  courses     OrganizationCourse[]
  subscription Subscription?
}

model OrganizationBranch {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

model OrganizationCourse {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

// ═══════════════════════════════════════════
// AUTH: Users & Sessions
// ═══════════════════════════════════════════

model User {
  id             String   @id @default(cuid())
  organizationId String
  login          String
  email          String?
  phone          String?
  password       String
  name           String
  role           String   @default("employee") // super_admin, org_admin, manager, teacher, parent, student, employee
  avatar         String?
  active         Boolean  @default(true)
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  sessions       Session[]
  devices        Device[]
  groups         Group[]      @relation("TeacherGroups")
  sentMessages   Message[]   @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  notifications  Notification[]
  auditLogs      AuditLog[]

  @@unique([organizationId, login])
  @@unique([organizationId, email])
  @@index([organizationId, role])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  deviceInfo   String?
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?
  phone     String?
  email     String?
  code      String
  type      String   // login, verify, reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code, type])
  @@index([email, code, type])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════
// CORE: Groups & Students
// ═══════════════════════════════════════════

model Group {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  course         String?
  teacherId      String?
  teacherName    String?
  room           String?
  status         String   @default("active")
  price          Float?
  startDate      DateTime?
  endDate        DateTime?
  monthDuration  Int?
  daysOfWeek     Json?    // ["monday","wednesday"]
  startTime      String?
  endTime        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  students       Student[]
  homework       Homework[]
  schedule       ScheduleEntry[]
  teacher        User?     @relation("TeacherGroups", fields: [teacherId], references: [id])

  @@index([organizationId, teacherId])
}

model Student {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  phone           String?
  groupId         String?
  course          String?
  parentIds       Json?    @default("[]")
  parentName      String?
  parentPhone     String?
  paymentStatus   String   @default("debt") // paid, debt, risk
  lastPaymentDate DateTime?
  riskGroup       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  group           Group?       @relation(fields: [groupId], references: [id])
  payments        Payment[]
  attendance      Attendance[]
  grades          Grade[]
  certificates    Certificate[]

  @@index([organizationId, groupId])
  @@index([organizationId, phone])
}

// ═══════════════════════════════════════════
// FINANCE
// ═══════════════════════════════════════════

model Payment {
  id              String   @id @default(cuid())
  organizationId  String
  studentId       String?
  studentName     String?
  groupId         String?
  groupName       String?
  amount          Float
  method          String   @default("Naqd") // Naqd, Click, Payme, Uzum, Bank, Stripe
  date            DateTime @default(now())
  note            String?
  transactionRef  String?  // payment gateway reference
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  student         Student?     @relation(fields: [studentId], references: [id])

  @@index([organizationId, studentId])
  @@index([organizationId, date])
}

model PaymentTransaction {
  id              String   @id @default(cuid())
  organizationId  String
  orderId         String   @unique
  provider        String   // click, payme, uzum, stripe
  amount          Float
  studentId       String?
  invoiceId       String?
  transactionId   String?
  status          String   @default("pending") // pending, paid, failed, cancelled
  paymentUrl      String?
  description     String?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Expense {
  id              String   @id @default(cuid())
  organizationId  String
  amount          Float
  description     String
  category        String?
  date            DateTime @default(now())
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, date])
  @@index([organizationId, category])
}

// ═══════════════════════════════════════════
// ATTENDANCE
// ═══════════════════════════════════════════

model Attendance {
  id              String   @id @default(cuid())
  organizationId  String
  studentId       String
  date            DateTime
  status          String   // present, absent, late
  note            String?
  markedById      String?
  markedByName    String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])

  @@unique([organizationId, studentId, date])
  @@index([organizationId, date])
}

// ═══════════════════════════════════════════
// EDUCATION
// ═══════════════════════════════════════════

model Homework {
  id              String   @id @default(cuid())
  organizationId  String
  groupId         String
  title           String
  description     String?
  deadline        DateTime?
  files           Json?    @default("[]")
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  group           Group        @relation(fields: [groupId], references: [id])

  @@index([organizationId, groupId])
}

model Grade {
  id              String   @id @default(cuid())
  organizationId  String
  studentId       String
  subject         String
  score           Float
  createdById     String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])

  @@index([organizationId, studentId])
  @@index([organizationId, subject])
}

model ScheduleEntry {
  id              String   @id @default(cuid())
  organizationId  String
  groupId         String
  subject         String
  teacherId       String?
  day             String   // monday, tuesday, etc.
  timeStart       String
  timeEnd         String
  room            String?
  createdById     String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  group           Group        @relation(fields: [groupId], references: [id])

  @@index([organizationId, groupId, day])
}

// ═══════════════════════════════════════════
// COMMUNICATION
// ═══════════════════════════════════════════

model Message {
  id              String   @id @default(cuid())
  organizationId  String
  content         String
  senderId        String
  receiverId      String
  studentId       String?
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  sender          User         @relation("SentMessages", fields: [senderId], references: [id])
  receiver        User         @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([organizationId, senderId, receiverId])
  @@index([organizationId, createdAt])
}

model Notification {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  title           String
  message         String
  type            String   @default("info") // info, success, warning, error
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, userId])
  @@index([organizationId, read])
}

// ═══════════════════════════════════════════
// LIBRARY, EXAMS, CERTIFICATES
// ═══════════════════════════════════════════

model Book {
  id              String   @id @default(cuid())
  organizationId  String
  title           String
  author          String?
  category        String?
  fileUrl         String?
  description     String?
  createdById     String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, category])
}

model Exam {
  id              String   @id @default(cuid())
  organizationId  String
  groupId         String?
  title           String
  questions       Json?    @default("[]")
  timeLimit       Int?
  maxScore        Float?
  date            DateTime?
  createdById     String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  results         ExamResult[]

  @@index([organizationId, groupId])
}

model ExamResult {
  id              String   @id @default(cuid())
  examId          String
  studentId       String?
  studentName     String?
  score           Float
  maxScore        Float?
  answers         Json?    @default("[]")
  submittedAt     DateTime @default(now())

  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
}

model Certificate {
  id                String   @id @default(cuid())
  organizationId    String
  studentId         String?
  studentName       String?
  type              String   @default("completion")
  certificateNumber String?
  issueDate         DateTime?
  description       String?
  issuedById        String?
  issuedByName      String?
  issuedAt          DateTime @default(now())

  organization      Organization @relation(fields: [organizationId], references: [id])
  student           Student?     @relation(fields: [studentId], references: [id])

  @@index([organizationId, studentId])
}

// ═══════════════════════════════════════════
// QR CODES & DEVICES
// ═══════════════════════════════════════════

model QrCode {
  id              String   @id @default(cuid())
  organizationId  String
  code            String   @unique
  active          Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, code])
}

model Device {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  deviceInfo      String?
  ip              String?
  platform        String?
  firstSeen       DateTime @default(now())
  lastActive      DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, userId])
}

// ═══════════════════════════════════════════
// AUDIT & SECURITY
// ═══════════════════════════════════════════

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  userName        String?
  action          String
  details         String?
  type            String   @default("general")
  ip              String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

model Subscription {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  plan            String   @default("free")
  status          String   @default("active")
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt     DateTime?
  stripeId        String?
  paymeId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
