# ─── Application ───
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/opencode_crm
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5434/opencode_crm
# For Neon/Production with pgBouncer:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=10
# DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require

# ─── Cache (Redis) ───
REDIS_URL=redis://localhost:6379

# ─── Authentication (JWT) ───
JWT_SECRET=generate_64_char_random_string_here
JWT_REFRESH_SECRET=generate_64_char_random_string_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=generate_32_char_random_string_here

# ─── Email (Resend) ───
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=OpenCode CRM

# ─── Push Notifications (Firebase) ───
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# ─── Payment Providers (Optional) ───
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_SERVICE_ID=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_TERMINAL_ID=
STRIPE_SECRET_KEY=

# ─── SMS (Optional) ───
SMS_API_KEY=
SMS_API_URL=

# ─── Storage (Optional) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=

# ─── Monitoring (Optional) ───
SENTRY_DSN=

# ─── Telegram (Optional) ───
TELEGRAM_BOT_TOKEN=